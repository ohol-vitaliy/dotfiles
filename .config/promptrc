if tput setaf 1 >/dev/null 2>&1; then
	tput sgr0 # reset colors
	bold=$(tput bold)
	reset=$(tput sgr0)
	# Solarized colors, taken from http://git.io/solarized-colors.
	black=$(tput setaf 0)
	blue=$(tput setaf 33)
	cyan=$(tput setaf 37)
	green=$(tput setaf 64)
	orange=$(tput setaf 166)
	purple=$(tput setaf 125)
	red=$(tput setaf 124)
	violet=$(tput setaf 61)
	white=$(tput setaf 15)
	yellow=$(tput setaf 136)
else
	bold=''
	reset='\033[0m'
	black='\033[1;30m'
	blue='\033[1;34m'
	cyan='\033[1;36m'
	green='\033[1;32m'
	orange='\033[1;33m'
	purple='\033[1;35m'
	red='\033[1;31m'
	violet='\033[1;35m'
	white='\033[1;37m'
	yellow='\033[1;33m'
fi

_venv_info() {
	[ -z "$VIRTUAL_ENV" ] && return
	printf '%s ' "${cyan}[$(basename "$VIRTUAL_ENV")]${reset}"
}

_short_pwd() {
	case "$PWD" in
	"$HOME")
		printf '%s' "${green}~${reset}"
		;;
	"$HOME"/*)
		printf '%s' "${green}~${PWD#"$HOME"}${reset}"
		;;
	*)
		printf '%s' "${green}$PWD${reset}"
		;;
	esac
}

_user_info() {
	_user="${USER:-$(id -un)}"
	case "$_user" in
	root | admin)
		printf '%s' "${red}$_user${reset}"
		;;
	*)
		printf '%s' "${blue}$_user${reset}"
		;;
	esac
}

